<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.zenora.controller.MilestoneController"
            prefWidth="980" prefHeight="680"
            styleClass="zn-root">
    <top>
        <HBox styleClass="zn-topbar" alignment="CENTER_LEFT" spacing="14">
            <Button text="← Kembali" styleClass="zn-btn-back" onAction="#back"/>
            <VBox spacing="2">
                <Label text="Milestone Planning" styleClass="zn-page-title"/>
                <Label text="BAGI TARGET MENJADI CHECKPOINT PERIODIK" styleClass="zn-page-badge"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="zn-scroll">
            <content>
                <HBox spacing="16" styleClass="zn-body">
                    <VBox spacing="0" styleClass="zn-panel" prefWidth="380">
                        <HBox styleClass="zn-panel-title-row" alignment="CENTER_LEFT" spacing="8">
                            <Label text="●" styleClass="zn-dot-cyan"/>
                            <Label text="Parameter Milestone" styleClass="zn-panel-title"/>
                        </HBox>
                        <Label text="TARGET DANA (RP)" styleClass="zn-field-label"/>
                        <TextField fx:id="targetField" styleClass="zn-field" promptText="contoh: 60000000" maxWidth="Infinity"/>
                        <Label text="TOTAL JANGKA WAKTU (BULAN)" styleClass="zn-field-label"/>
                        <TextField fx:id="totalMonthsField" styleClass="zn-field" promptText="contoh: 24" maxWidth="Infinity"/>
                        <Label text="PERIODE MILESTONE (BULAN)" styleClass="zn-field-label"/>
                        <TextField fx:id="periodField" styleClass="zn-field" promptText="contoh: 6" maxWidth="Infinity"/>
                        <Label text="Checkpoint dicetak setiap N bulan." styleClass="zn-hint"/>
                        <Label text="RETURN INVESTASI (% / TAHUN)" styleClass="zn-field-label"/>
                        <TextField fx:id="rateField" styleClass="zn-field" promptText="0 = tanpa bunga" maxWidth="Infinity"/>
                        <Region VBox.vgrow="ALWAYS" minHeight="20"/>
                        <Button text="📍  Buat Milestone" styleClass="zn-btn-primary" maxWidth="Infinity" onAction="#generate"/>
                    </VBox>
                    <VBox spacing="0" styleClass="zn-panel" HBox.hgrow="ALWAYS">
                        <HBox styleClass="zn-panel-title-row" alignment="CENTER_LEFT" spacing="8">
                            <Label text="●" styleClass="zn-dot-cyan"/>
                            <Label text="Daftar Milestone" styleClass="zn-panel-title"/>
                        </HBox>
                        <Region minHeight="14"/>
                        <TextArea fx:id="resultArea" styleClass="zn-result-area"
                                  wrapText="true" editable="false"
                                  VBox.vgrow="ALWAYS" prefHeight="500"
                                  promptText="Isi form lalu klik Buat Milestone..."/>
                    </VBox>
                </HBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
