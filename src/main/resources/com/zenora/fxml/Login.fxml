<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.zenora.controller.LoginController"
           prefWidth="1200" prefHeight="760"
           style="-fx-background-color: #060810;">

    <HBox fillHeight="true">

        <StackPane prefWidth="560" minWidth="560" maxWidth="560"
                   style="-fx-background-color: #0B0E1C;">

            <!-- Decorative grid overlay -->
            <Region style="-fx-background-color: transparent;
                           -fx-border-color: rgba(79,70,229,0.06);
                           -fx-border-width: 0;
                           -fx-padding: 0;"/>

            <!-- Gradient accent strip at top -->
            <Region VBox.vgrow="NEVER"
                    style="-fx-background-color: linear-gradient(to bottom, rgba(79,70,229,0.18), transparent);
                           -fx-min-height: 300;
                           -fx-max-height: 300;
                           -fx-min-width: 560;
                           -fx-max-width: 560;"
                    StackPane.alignment="TOP_LEFT"/>

            <!-- Content -->
            <VBox alignment="TOP_LEFT" spacing="0"
                  style="-fx-padding: 56 52 56 52;">

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="44" prefHeight="44"
                               style="-fx-background-color: #4F46E5;
                                      -fx-background-radius: 12;">
                        <Label text="Z"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 20px;
                                      -fx-font-weight: 900;"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label text="Zenora"
                               style="-fx-text-fill: #F0F4FF;
                                      -fx-font-size: 18px;
                                      -fx-font-weight: 800;"/>
                        <Label text="PERSONAL FINANCE"
                               style="-fx-text-fill: #4F46E5;
                                      -fx-font-size: 9px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.12em;"/>
                    </VBox>
                </HBox>

                <Region prefHeight="72"/>

                <!-- Hero headline -->
                <VBox spacing="4">
                    <Label text="Kendali Penuh"
                           style="-fx-text-fill: #E8EEFF;
                                  -fx-font-size: 40px;
                                  -fx-font-weight: 800;"/>
                    <Label text="Atas Finansialmu"
                           style="-fx-text-fill: #6366F1;
                                  -fx-font-size: 40px;
                                  -fx-font-weight: 800;"/>
                </VBox>

                <Region prefHeight="24"/>

                <Label text="Platform manajemen keuangan pribadi yang cerdas,&#10;intuitif, dan dirancang untuk masa depanmu."
                       wrapText="true"
                       style="-fx-text-fill: #64748B;
                              -fx-font-size: 14px;
                              -fx-line-spacing: 4;
                              -fx-max-width: 380;"/>

                <Region prefHeight="56"/>

                <!-- Stats row -->
                <HBox spacing="0"
                      style="-fx-background-color: rgba(255,255,255,0.03);
                             -fx-background-radius: 16;
                             -fx-border-color: rgba(255,255,255,0.06);
                             -fx-border-radius: 16;
                             -fx-border-width: 1;">
                    <VBox alignment="CENTER" spacing="4"
                          style="-fx-padding: 20 32; -fx-min-width: 140;">
                        <Label text="6+"
                               style="-fx-text-fill: #818CF8;
                                      -fx-font-size: 28px;
                                      -fx-font-weight: 800;"/>
                        <Label text="MODULES"
                               style="-fx-text-fill: #475569;
                                      -fx-font-size: 9px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.1em;"/>
                    </VBox>
                    <Region style="-fx-background-color: rgba(255,255,255,0.05);
                                   -fx-min-width: 1; -fx-max-width: 1;
                                   -fx-min-height: 60; -fx-max-height: 60;"
                            VBox.vgrow="NEVER"/>
                    <VBox alignment="CENTER" spacing="4"
                          style="-fx-padding: 20 32; -fx-min-width: 140;">
                        <Label text="100%"
                               style="-fx-text-fill: #22D3EE;
                                      -fx-font-size: 28px;
                                      -fx-font-weight: 800;"/>
                        <Label text="LOKAL"
                               style="-fx-text-fill: #475569;
                                      -fx-font-size: 9px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.1em;"/>
                    </VBox>
                    <Region style="-fx-background-color: rgba(255,255,255,0.05);
                                   -fx-min-width: 1; -fx-max-width: 1;
                                   -fx-min-height: 60; -fx-max-height: 60;"
                            VBox.vgrow="NEVER"/>
                    <VBox alignment="CENTER" spacing="4"
                          style="-fx-padding: 20 32; -fx-min-width: 140;">
                        <Label text="Aman"
                               style="-fx-text-fill: #34D399;
                                      -fx-font-size: 28px;
                                      -fx-font-weight: 800;"/>
                        <Label text="DATA PRIVASI"
                               style="-fx-text-fill: #475569;
                                      -fx-font-size: 9px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.1em;"/>
                    </VBox>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Feature pills -->
                <HBox spacing="8">
                    <Label text="⬡  AI Analytics"
                           style="-fx-background-color: rgba(79,70,229,0.12);
                                  -fx-text-fill: #818CF8;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: 700;
                                  -fx-background-radius: 20;
                                  -fx-border-color: rgba(99,102,241,0.22);
                                  -fx-border-radius: 20;
                                  -fx-border-width: 1;
                                  -fx-padding: 6 14;"/>
                    <Label text="⬡  Goal Tracking"
                           style="-fx-background-color: rgba(34,211,238,0.08);
                                  -fx-text-fill: #22D3EE;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: 700;
                                  -fx-background-radius: 20;
                                  -fx-border-color: rgba(34,211,238,0.18);
                                  -fx-border-radius: 20;
                                  -fx-border-width: 1;
                                  -fx-padding: 6 14;"/>
                    <Label text="⬡  Laporan Real-time"
                           style="-fx-background-color: rgba(52,211,153,0.08);
                                  -fx-text-fill: #34D399;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: 700;
                                  -fx-background-radius: 20;
                                  -fx-border-color: rgba(52,211,153,0.18);
                                  -fx-border-radius: 20;
                                  -fx-border-width: 1;
                                  -fx-padding: 6 14;"/>
                </HBox>
            </VBox>
        </StackPane>

        <!-- ═══════════════════════════════════════
             RIGHT PANEL — Login Form
        ════════════════════════════════════════ -->
        <VBox alignment="CENTER"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color: #060810;
                     -fx-padding: 56 80;">

            <VBox maxWidth="400" minWidth="400">

                <!-- Form header -->
                <VBox spacing="6">
                    <Label text="SIGN IN"
                           style="-fx-text-fill: #4F46E5;
                                  -fx-font-size: 10px;
                                  -fx-font-weight: 800;
                                  -fx-font-family: 'Consolas', monospace;
                                  -fx-letter-spacing: 0.14em;"/>
                    <Label text="Selamat kembali"
                           style="-fx-text-fill: #E8EEFF;
                                  -fx-font-size: 30px;
                                  -fx-font-weight: 800;"/>
                    <Label text="Masukkan kredensial Anda untuk melanjutkan"
                           style="-fx-text-fill: #475569;
                                  -fx-font-size: 13px;"/>
                </VBox>

                <Region prefHeight="44"/>

                <!-- Form card -->
                <VBox spacing="0"
                      style="-fx-background-color: #0D1022;
                             -fx-background-radius: 20;
                             -fx-border-color: rgba(255,255,255,0.07);
                             -fx-border-radius: 20;
                             -fx-border-width: 1;
                             -fx-padding: 36 32 32 32;">

                    <!-- Username field -->
                    <VBox spacing="8">
                        <Label text="USERNAME"
                               style="-fx-text-fill: #6366F1;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.1em;"/>
                        <TextField fx:id="usernameField"
                                   promptText="Masukkan username Anda"
                                   minHeight="46"
                                   style="-fx-background-color: #060810;
                                          -fx-background-radius: 11;
                                          -fx-border-color: rgba(255,255,255,0.08);
                                          -fx-border-radius: 11;
                                          -fx-border-width: 1;
                                          -fx-text-fill: #E2E8F0;
                                          -fx-prompt-text-fill: #334155;
                                          -fx-font-size: 13px;
                                          -fx-padding: 0 16;"/>
                    </VBox>

                    <Region prefHeight="22"/>

                    <!-- Password field -->
                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="PASSWORD"
                                   style="-fx-text-fill: #6366F1;
                                          -fx-font-size: 10px;
                                          -fx-font-weight: 700;
                                          -fx-font-family: 'Consolas', monospace;
                                          -fx-letter-spacing: 0.1em;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Lupa password?"
                                    style="-fx-background-color: transparent;
                                           -fx-text-fill: #475569;
                                           -fx-font-size: 11px;
                                           -fx-cursor: hand;
                                           -fx-padding: 0;
                                           -fx-border-color: transparent;"/>
                        </HBox>
                        <PasswordField fx:id="passwordField"
                                       promptText="Masukkan password Anda"
                                       minHeight="46"
                                       style="-fx-background-color: #060810;
                                              -fx-background-radius: 11;
                                              -fx-border-color: rgba(255,255,255,0.08);
                                              -fx-border-radius: 11;
                                              -fx-border-width: 1;
                                              -fx-text-fill: #E2E8F0;
                                              -fx-prompt-text-fill: #334155;
                                              -fx-font-size: 13px;
                                              -fx-padding: 0 16;"/>
                    </VBox>

                    <Region prefHeight="10"/>

                    <!-- Error / loading states -->
                    <Label fx:id="errorLabel" text=""
                           wrapText="true"
                           style="-fx-text-fill: #F87171;
                                  -fx-font-size: 11px;
                                  -fx-padding: 6 0 0 0;"/>
                    <Label fx:id="loadingLabel" text="Memverifikasi akun…"
                           visible="false" managed="false"
                           style="-fx-text-fill: #6366F1;
                                  -fx-font-size: 11px;
                                  -fx-padding: 6 0 0 0;"/>

                    <Region prefHeight="26"/>

                    <!-- Login button -->
                    <Button fx:id="loginButton"
                            text="Masuk ke Dashboard"
                            onAction="#handleLogin"
                            maxWidth="999"
                            minHeight="50"
                            style="-fx-background-color: #4F46E5;
                                   -fx-background-radius: 12;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-cursor: hand;
                                   -fx-border-color: transparent;"/>

                    <Region prefHeight="28"/>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="12">
                        <Region HBox.hgrow="ALWAYS"
                                style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-min-height: 1; -fx-max-height: 1;"/>
                        <Label text="ATAU"
                               style="-fx-text-fill: #334155;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;"/>
                        <Region HBox.hgrow="ALWAYS"
                                style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-min-height: 1; -fx-max-height: 1;"/>
                    </HBox>

                    <Region prefHeight="24"/>

                    <!-- Register link -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Belum punya akun?"
                               style="-fx-text-fill: #475569;
                                      -fx-font-size: 12px;"/>
                        <Button text="Buat akun baru"
                                onAction="#goToRegister"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #818CF8;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: 700;
                                       -fx-cursor: hand;
                                       -fx-padding: 0;
                                       -fx-border-color: transparent;"/>
                    </HBox>
                </VBox>

                <Region prefHeight="32"/>

                <!-- Footer note -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="🔒"
                           style="-fx-font-size: 11px; -fx-opacity: 0.4;"/>
                    <Label text="Data Anda tersimpan secara lokal dan terenkripsi"
                           style="-fx-text-fill: #334155;
                                  -fx-font-size: 11px;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
