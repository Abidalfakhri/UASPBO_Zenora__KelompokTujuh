<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.zenora.controller.LoginController"
           styleClass="zn-root"
           prefWidth="1100" prefHeight="700">

    <!-- Background pattern -->
    <VBox alignment="CENTER" spacing="0">

        <!-- Top accent bar -->
        <Region minHeight="3" maxHeight="3"
                style="-fx-background-color: linear-gradient(to right, #4F46E5, #7C3AED, #22D3EE); -fx-min-width: 9999;"/>

        <!-- Main content area -->
        <HBox alignment="CENTER" VBox.vgrow="ALWAYS" fillHeight="true">

            <!-- LEFT PANEL — Branding -->
            <VBox alignment="CENTER_LEFT" spacing="0" minWidth="480" maxWidth="480"
                  style="-fx-background-color: #0F1117; -fx-padding: 80 64;">

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Z" styleClass="zn-logo-mark"/>
                    <Label text="Zenora" style="-fx-font-size:22px; -fx-font-weight:800; -fx-text-fill:#F0F0F6;"/>
                </HBox>

                <Region minHeight="60"/>

                <!-- Tagline -->
                <Label text="Personal Financial Suite"
                       style="-fx-font-size:11px; -fx-font-weight:700; -fx-text-fill:#4F46E5;
                              -fx-font-family:'Consolas',monospace; -fx-padding:0 0 14 0;"/>
                <Label text="Kelola tujuan keuanganmu&#10;dengan lebih terstruktur."
                       wrapText="true"
                       style="-fx-font-size:30px; -fx-font-weight:800; -fx-text-fill:#F0F0F6;
                              -fx-line-spacing:6;"/>

                <Region minHeight="24"/>
                <Label text="Lacak tabungan, dana darurat, pensiun,&#10;dan skenario keuangan di satu tempat."
                       wrapText="true"
                       style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-line-spacing:4;"/>

                <Region minHeight="60"/>

                <!-- Stats row -->
                <HBox spacing="40">
                    <VBox spacing="2">
                        <Label text="6" style="-fx-font-size:28px; -fx-font-weight:800; -fx-text-fill:#818CF8;"/>
                        <Label text="MODULES" style="-fx-font-size:9px; -fx-font-weight:700; -fx-text-fill:#374151; -fx-font-family:'Consolas',monospace;"/>
                    </VBox>
                    <Region style="-fx-background-color:rgba(255,255,255,0.06); -fx-min-width:1; -fx-max-width:1;"/>
                    <VBox spacing="2">
                        <Label text="∞" style="-fx-font-size:28px; -fx-font-weight:800; -fx-text-fill:#22D3EE;"/>
                        <Label text="SCENARIOS" style="-fx-font-size:9px; -fx-font-weight:700; -fx-text-fill:#374151; -fx-font-family:'Consolas',monospace;"/>
                    </VBox>
                    <Region style="-fx-background-color:rgba(255,255,255,0.06); -fx-min-width:1; -fx-max-width:1;"/>
                    <VBox spacing="2">
                        <Label text="H2" style="-fx-font-size:28px; -fx-font-weight:800; -fx-text-fill:#34D399;"/>
                        <Label text="DATABASE" style="-fx-font-size:9px; -fx-font-weight:700; -fx-text-fill:#374151; -fx-font-family:'Consolas',monospace;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Divider -->
            <Region minWidth="1" maxWidth="1"
                    style="-fx-background-color: rgba(255,255,255,0.06);"
                    VBox.vgrow="ALWAYS"/>

            <!-- RIGHT PANEL — Login Form -->
            <VBox alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #0F1117; -fx-padding: 80 64;">

                <VBox maxWidth="380" spacing="0">

                    <!-- Form Header -->
                    <Label text="Masuk ke akun kamu"
                           style="-fx-font-size:22px; -fx-font-weight:800; -fx-text-fill:#F0F0F6;"/>
                    <Region minHeight="6"/>
                    <Label text="Gunakan username dan password yang sudah kamu daftarkan."
                           wrapText="true"
                           style="-fx-font-size:12px; -fx-text-fill:#6B7280;"/>

                    <Region minHeight="36"/>

                    <!-- Card -->
                    <VBox spacing="0" styleClass="zn-panel">
                        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                        <!-- Username -->
                        <Label text="USERNAME" styleClass="zn-field-label"/>
                        <TextField fx:id="usernameField" promptText="Masukkan username"
                                   styleClass="zn-field" maxWidth="9999"/>

                        <Region minHeight="16"/>

                        <!-- Password -->
                        <Label text="PASSWORD" styleClass="zn-field-label"/>
                        <PasswordField fx:id="passwordField" promptText="Masukkan password"
                                       styleClass="zn-field" maxWidth="9999"/>

                        <Region minHeight="8"/>

                        <!-- Error label -->
                        <Label fx:id="errorLabel" text=""
                               style="-fx-font-size:11px; -fx-text-fill:#F87171; -fx-font-weight:600;"/>

                        <!-- Loading label -->
                        <Label fx:id="loadingLabel" text="⟳  Memeriksa kredensial..."
                               style="-fx-font-size:11px; -fx-text-fill:#818CF8; -fx-font-weight:600;"/>

                        <Region minHeight="20"/>

                        <!-- Login Button -->
                        <Button fx:id="loginButton" text="Masuk →"
                                styleClass="zn-btn-primary"
                                maxWidth="9999" minHeight="42"
                                onAction="#handleLogin"
                                style="-fx-font-size:14px; -fx-font-weight:700;"/>
                    </VBox>

                    <Region minHeight="20"/>

                    <!-- Register link -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Belum punya akun?"
                               style="-fx-font-size:12px; -fx-text-fill:#6B7280;"/>
                        <Button text="Daftar sekarang"
                                styleClass="zn-btn-back"
                                onAction="#goToRegister"
                                style="-fx-font-size:12px; -fx-text-fill:#818CF8; -fx-font-weight:600;
                                       -fx-background-color:transparent; -fx-cursor:hand; -fx-padding:0;
                                       -fx-border-color:transparent;"/>
                    </HBox>

                    <Region minHeight="32"/>

                    <!-- Default credentials hint -->
                    <VBox spacing="4"
                          style="-fx-background-color:rgba(79,70,229,0.08); -fx-background-radius:8;
                                 -fx-border-color:rgba(79,70,229,0.25); -fx-border-radius:8;
                                 -fx-border-width:1; -fx-padding:12 14;">
                        <Label text="AKUN DEFAULT (DEVELOPMENT)"
                               style="-fx-font-size:9px; -fx-font-weight:700; -fx-text-fill:#4F46E5;
                                      -fx-font-family:'Consolas',monospace;"/>
                        <Label text="admin / admin123   ·   user / user123"
                               style="-fx-font-size:11px; -fx-text-fill:#818CF8;
                                      -fx-font-family:'Consolas',monospace;"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</StackPane>
