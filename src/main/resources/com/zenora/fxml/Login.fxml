<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.zenora.controller.LoginController"
           style="-fx-background-color: linear-gradient(to bottom right, #0B0F19, #111827);"
           prefWidth="1100" minWidth="780"
           prefHeight="760">

    <!-- Main Container -->
    <HBox alignment="CENTER">

        <!-- LEFT SIDE -->
        <VBox alignment="CENTER_LEFT"
              spacing="0"
              minWidth="520"
              maxWidth="520"
              style="-fx-background-color:
                     linear-gradient(to bottom right, #0F172A, #111827);
                     -fx-padding: 80 70;">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="14">

                <StackPane prefWidth="52" prefHeight="52"
                           style="-fx-background-color:
                                  linear-gradient(to bottom right, #6366F1, #8B5CF6);
                                  -fx-background-radius: 16;">

                    <Label text="Z"
                           style="-fx-text-fill:white;
                                  -fx-font-size:24px;
                                  -fx-font-weight:900;"/>
                </StackPane>

                <VBox spacing="2">
                    <Label text="Zenora"
                           style="-fx-text-fill:#F8FAFC;
                                  -fx-font-size:24px;
                                  -fx-font-weight:900;"/>

                    <Label text="Personal Finance Platform"
                           style="-fx-text-fill:#818CF8;
                                  -fx-font-size:11px;
                                  -fx-font-weight:700;
                                  -fx-font-family:'Consolas';"/>
                </VBox>
            </HBox>

            <Region minHeight="80"/>

            <!-- Hero Text -->
            <Label text="Atur Keuangan&#10;Dengan Lebih Modern"
                   wrapText="true"
                   style="-fx-text-fill:#F8FAFC;
                          -fx-font-size:38px;
                          -fx-font-weight:900;
                          -fx-line-spacing:8;"/>

            <Region minHeight="24"/>

            <Label text="Pantau tabungan, dana darurat, target finansial, dan seluruh perencanaan keuangan dalam satu dashboard yang elegan."
                   wrapText="true"
                   maxWidth="360"
                   style="-fx-text-fill:#94A3B8;
                          -fx-font-size:14px;
                          -fx-line-spacing:5;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom Feature Cards -->
            <HBox spacing="18">

                <VBox spacing="6"
                      prefWidth="120"
                      style="-fx-background-color: rgba(255,255,255,0.04);
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-padding:18;">

                    <Label text="6+"
                           style="-fx-text-fill:#818CF8;
                                  -fx-font-size:24px;
                                  -fx-font-weight:900;"/>

                    <Label text="Financial Modules"
                           wrapText="true"
                           style="-fx-text-fill:#94A3B8;
                                  -fx-font-size:11px;"/>
                </VBox>

                <VBox spacing="6"
                      prefWidth="120"
                      style="-fx-background-color: rgba(255,255,255,0.04);
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-padding:18;">

                    <Label text="∞"
                           style="-fx-text-fill:#22D3EE;
                                  -fx-font-size:24px;
                                  -fx-font-weight:900;"/>

                    <Label text="Scenario Planning"
                           wrapText="true"
                           style="-fx-text-fill:#94A3B8;
                                  -fx-font-size:11px;"/>
                </VBox>

                <VBox spacing="6"
                      prefWidth="120"
                      style="-fx-background-color: rgba(255,255,255,0.04);
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-padding:18;">

                    <Label text="Secure"
                           style="-fx-text-fill:#34D399;
                                  -fx-font-size:20px;
                                  -fx-font-weight:900;"/>

                    <Label text="Encrypted Storage"
                           wrapText="true"
                           style="-fx-text-fill:#94A3B8;
                                  -fx-font-size:11px;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- RIGHT SIDE -->
        <StackPane prefWidth="620"
                   style="-fx-background-color:#0B1220;">

            <VBox alignment="CENTER"
                  maxWidth="390"
                  spacing="0">

                <!-- Header -->
                <Label text="Welcome Back"
                       style="-fx-text-fill:#F8FAFC;
                              -fx-font-size:28px;
                              -fx-font-weight:900;"/>

                <Region minHeight="8"/>

                <Label text="Masuk untuk melanjutkan ke dashboard Zenora."
                       wrapText="true"
                       style="-fx-text-fill:#94A3B8;
                              -fx-font-size:13px;"/>

                <Region minHeight="34"/>

                <!-- Login Card -->
                <VBox spacing="0"
                      style="-fx-background-color: rgba(17,24,39,0.95);
                             -fx-background-radius: 26;
                             -fx-border-radius: 26;
                             -fx-border-color: rgba(255,255,255,0.06);
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 40, 0.2, 0, 10);">

                    <padding>
                        <Insets top="34" right="34" bottom="34" left="34"/>
                    </padding>

                    <!-- Username -->
                    <Label text="USERNAME"
                           style="-fx-text-fill:#64748B;
                                  -fx-font-size:10px;
                                  -fx-font-weight:800;
                                  -fx-letter-spacing:1.5;"/>

                    <Region minHeight="10"/>

                    <TextField fx:id="usernameField"
                               promptText="Masukkan username"
                               style="
                                   -fx-background-color:#111827;
                                   -fx-background-radius:14;
                                   -fx-border-radius:14;
                                   -fx-border-color:#1E293B;
                                   -fx-border-width:1;
                                   -fx-text-fill:white;
                                   -fx-prompt-text-fill:#64748B;
                                   -fx-font-size:13px;
                                   -fx-padding:14 16;"
                               minHeight="48"/>

                    <Region minHeight="18"/>

                    <!-- Password -->
                    <Label text="PASSWORD"
                           style="-fx-text-fill:#64748B;
                                  -fx-font-size:10px;
                                  -fx-font-weight:800;
                                  -fx-letter-spacing:1.5;"/>

                    <Region minHeight="10"/>

                    <PasswordField fx:id="passwordField"
                                   promptText="Masukkan password"
                                   style="
                                       -fx-background-color:#111827;
                                       -fx-background-radius:14;
                                       -fx-border-radius:14;
                                       -fx-border-color:#1E293B;
                                       -fx-border-width:1;
                                       -fx-text-fill:white;
                                       -fx-prompt-text-fill:#64748B;
                                       -fx-font-size:13px;
                                       -fx-padding:14 16;"
                                   minHeight="48"/>

                    <Region minHeight="12"/>

                    <!-- Error -->
                    <Label fx:id="errorLabel"
                           text=""
                           style="-fx-text-fill:#F87171;
                                  -fx-font-size:11px;
                                  -fx-font-weight:700;"/>

                    <!-- Loading -->
                    <Label fx:id="loadingLabel"
                           text="Memverifikasi akun..."
                           visible="false"
                           managed="false"
                           style="-fx-text-fill:#818CF8;
                                  -fx-font-size:11px;
                                  -fx-font-weight:700;"/>

                    <Region minHeight="26"/>

                    <!-- Button -->
                    <Button fx:id="loginButton"
                            text="Masuk ke Dashboard"
                            onAction="#handleLogin"
                            maxWidth="999"
                            minHeight="50"
                            style="
                                -fx-background-color:
                                linear-gradient(to right, #6366F1, #8B5CF6);
                                -fx-background-radius:16;
                                -fx-text-fill:white;
                                -fx-font-size:14px;
                                -fx-font-weight:800;
                                -fx-cursor:hand;"/>

                    <Region minHeight="24"/>

                    <!-- Register -->
                    <HBox alignment="CENTER" spacing="6">

                        <Label text="Belum punya akun?"
                               style="-fx-text-fill:#64748B;
                                      -fx-font-size:12px;"/>

                        <Button text="Daftar"
                                onAction="#goToRegister"
                                style="
                                    -fx-background-color: transparent;
                                    -fx-text-fill:#818CF8;
                                    -fx-font-size:12px;
                                    -fx-font-weight:700;
                                    -fx-cursor:hand;
                                    -fx-padding:0;
                                    -fx-border-color:transparent;"/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </HBox>
</StackPane>