<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.zenora.controller.RegisterController"
           prefWidth="1200" prefHeight="820"
           style="-fx-background-color: #060810;">

    <HBox fillHeight="true">

        <StackPane prefWidth="520" minWidth="520" maxWidth="520"
                   style="-fx-background-color: #0B0E1C;">

            <!-- Top gradient accent -->
            <Region style="-fx-background-color: linear-gradient(to bottom, rgba(124,58,237,0.16), transparent);
                           -fx-min-height: 320; -fx-max-height: 320;
                           -fx-min-width: 520; -fx-max-width: 520;"
                    StackPane.alignment="TOP_LEFT"/>

            <VBox alignment="TOP_LEFT" spacing="0"
                  style="-fx-padding: 56 52 56 52;">

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <StackPane prefWidth="44" prefHeight="44"
                               style="-fx-background-color: #7C3AED;
                                      -fx-background-radius: 12;">
                        <Label text="Z"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 20px;
                                      -fx-font-weight: 900;"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label text="Zenora"
                               style="-fx-text-fill: #F0F4FF;
                                      -fx-font-size: 18px;
                                      -fx-font-weight: 800;"/>
                        <Label text="PERSONAL FINANCE"
                               style="-fx-text-fill: #7C3AED;
                                      -fx-font-size: 9px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.12em;"/>
                    </VBox>
                </HBox>

                <Region prefHeight="72"/>

                <!-- Hero headline -->
                <VBox spacing="4">
                    <Label text="Mulai Perjalanan"
                           style="-fx-text-fill: #E8EEFF;
                                  -fx-font-size: 38px;
                                  -fx-font-weight: 800;"/>
                    <Label text="Finansial Cerdas"
                           style="-fx-text-fill: #A78BFA;
                                  -fx-font-size: 38px;
                                  -fx-font-weight: 800;"/>
                </VBox>

                <Region prefHeight="24"/>

                <Label text="Zenora membantu kamu merencanakan masa depan&#10;finansial dengan alat yang tepat dan dashboard&#10;yang modern."
                       wrapText="true"
                       style="-fx-text-fill: #64748B;
                              -fx-font-size: 13px;
                              -fx-line-spacing: 5;
                              -fx-max-width: 380;"/>

                <Region prefHeight="52"/>

                <!-- Feature list -->
                <VBox spacing="16">
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <StackPane prefWidth="32" prefHeight="32"
                                   style="-fx-background-color: rgba(124,58,237,0.14);
                                          -fx-background-radius: 8;">
                            <Label text="✦"
                                   style="-fx-text-fill: #A78BFA;
                                          -fx-font-size: 12px;"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="Simulasi tabungan otomatis"
                                   style="-fx-text-fill: #CBD5E1;
                                          -fx-font-size: 13px;
                                          -fx-font-weight: 700;"/>
                            <Label text="Hitung bunga dan proyeksi pertumbuhan aset"
                                   style="-fx-text-fill: #475569;
                                          -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <StackPane prefWidth="32" prefHeight="32"
                                   style="-fx-background-color: rgba(34,211,238,0.10);
                                          -fx-background-radius: 8;">
                            <Label text="✦"
                                   style="-fx-text-fill: #22D3EE;
                                          -fx-font-size: 12px;"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="Dana darurat &amp; pensiun"
                                   style="-fx-text-fill: #CBD5E1;
                                          -fx-font-size: 13px;
                                          -fx-font-weight: 700;"/>
                            <Label text="Rencanakan keamanan finansial jangka panjang"
                                   style="-fx-text-fill: #475569;
                                          -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <StackPane prefWidth="32" prefHeight="32"
                                   style="-fx-background-color: rgba(52,211,153,0.10);
                                          -fx-background-radius: 8;">
                            <Label text="✦"
                                   style="-fx-text-fill: #34D399;
                                          -fx-font-size: 12px;"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="Dashboard interaktif"
                                   style="-fx-text-fill: #CBD5E1;
                                          -fx-font-size: 13px;
                                          -fx-font-weight: 700;"/>
                            <Label text="Visualisasi data finansial yang mudah dipahami"
                                   style="-fx-text-fill: #475569;
                                          -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <StackPane prefWidth="32" prefHeight="32"
                                   style="-fx-background-color: rgba(251,191,36,0.10);
                                          -fx-background-radius: 8;">
                            <Label text="✦"
                                   style="-fx-text-fill: #FBBF24;
                                          -fx-font-size: 12px;"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="Data privat dan terenkripsi"
                                   style="-fx-text-fill: #CBD5E1;
                                          -fx-font-size: 13px;
                                          -fx-font-weight: 700;"/>
                            <Label text="Semua data tersimpan lokal di perangkatmu"
                                   style="-fx-text-fill: #475569;
                                          -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Bottom tagline -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region style="-fx-background-color: #7C3AED;
                                   -fx-min-width: 3; -fx-max-width: 3;
                                   -fx-min-height: 36; -fx-max-height: 36;
                                   -fx-background-radius: 2;"/>
                    <Label text="Gratis selamanya — tidak ada biaya tersembunyi"
                           style="-fx-text-fill: #64748B;
                                  -fx-font-size: 12px;
                                  -fx-font-style: italic;"/>
                </HBox>
            </VBox>
        </StackPane>

        <!-- ═══════════════════════════════════════
             RIGHT PANEL — Register Form
        ════════════════════════════════════════ -->
        <VBox alignment="CENTER"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color: #060810;
                     -fx-padding: 52 80;">

            <VBox maxWidth="420" minWidth="420">

                <!-- Form header -->
                <VBox spacing="6">
                    <Label text="CREATE ACCOUNT"
                           style="-fx-text-fill: #7C3AED;
                                  -fx-font-size: 10px;
                                  -fx-font-weight: 800;
                                  -fx-font-family: 'Consolas', monospace;
                                  -fx-letter-spacing: 0.14em;"/>
                    <Label text="Buat akun baru"
                           style="-fx-text-fill: #E8EEFF;
                                  -fx-font-size: 30px;
                                  -fx-font-weight: 800;"/>
                    <Label text="Daftar untuk mulai menggunakan Zenora secara gratis"
                           style="-fx-text-fill: #475569;
                                  -fx-font-size: 13px;"/>
                </VBox>

                <Region prefHeight="40"/>

                <!-- Form card -->
                <VBox spacing="0"
                      style="-fx-background-color: #0D1022;
                             -fx-background-radius: 20;
                             -fx-border-color: rgba(255,255,255,0.07);
                             -fx-border-radius: 20;
                             -fx-border-width: 1;
                             -fx-padding: 36 32 32 32;">

                    <!-- Username -->
                    <VBox spacing="8">
                        <Label text="USERNAME"
                               style="-fx-text-fill: #8B5CF6;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.1em;"/>
                        <TextField fx:id="usernameField"
                                   promptText="Pilih username yang unik"
                                   minHeight="46"
                                   style="-fx-background-color: #060810;
                                          -fx-background-radius: 11;
                                          -fx-border-color: rgba(255,255,255,0.08);
                                          -fx-border-radius: 11;
                                          -fx-border-width: 1;
                                          -fx-text-fill: #E2E8F0;
                                          -fx-prompt-text-fill: #334155;
                                          -fx-font-size: 13px;
                                          -fx-padding: 0 16;"/>
                    </VBox>

                    <Region prefHeight="20"/>

                    <!-- Password -->
                    <VBox spacing="8">
                        <Label text="PASSWORD"
                               style="-fx-text-fill: #8B5CF6;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.1em;"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Minimal 6 karakter"
                                       minHeight="46"
                                       style="-fx-background-color: #060810;
                                              -fx-background-radius: 11;
                                              -fx-border-color: rgba(255,255,255,0.08);
                                              -fx-border-radius: 11;
                                              -fx-border-width: 1;
                                              -fx-text-fill: #E2E8F0;
                                              -fx-prompt-text-fill: #334155;
                                              -fx-font-size: 13px;
                                              -fx-padding: 0 16;"/>
                    </VBox>

                    <Region prefHeight="20"/>

                    <!-- Confirm Password -->
                    <VBox spacing="8">
                        <Label text="KONFIRMASI PASSWORD"
                               style="-fx-text-fill: #8B5CF6;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;
                                      -fx-letter-spacing: 0.1em;"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Ulangi password"
                                       minHeight="46"
                                       style="-fx-background-color: #060810;
                                              -fx-background-radius: 11;
                                              -fx-border-color: rgba(255,255,255,0.08);
                                              -fx-border-radius: 11;
                                              -fx-border-width: 1;
                                              -fx-text-fill: #E2E8F0;
                                              -fx-prompt-text-fill: #334155;
                                              -fx-font-size: 13px;
                                              -fx-padding: 0 16;"/>
                    </VBox>

                    <Region prefHeight="10"/>

                    <!-- Status labels -->
                    <Label fx:id="errorLabel" text=""
                           wrapText="true"
                           style="-fx-text-fill: #F87171;
                                  -fx-font-size: 11px;
                                  -fx-padding: 6 0 0 0;"/>
                    <Label fx:id="successLabel" text=""
                           style="-fx-text-fill: #34D399;
                                  -fx-font-size: 11px;
                                  -fx-padding: 6 0 0 0;"/>
                    <Label fx:id="loadingLabel" text="Membuat akun…"
                           visible="false" managed="false"
                           style="-fx-text-fill: #8B5CF6;
                                  -fx-font-size: 11px;
                                  -fx-padding: 6 0 0 0;"/>

                    <Region prefHeight="26"/>

                    <!-- Register button -->
                    <Button fx:id="registerButton"
                            text="Buat Akun Sekarang"
                            onAction="#handleRegister"
                            maxWidth="999"
                            minHeight="50"
                            style="-fx-background-color: #7C3AED;
                                   -fx-background-radius: 12;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: 800;
                                   -fx-cursor: hand;
                                   -fx-border-color: transparent;"/>

                    <Region prefHeight="28"/>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="12">
                        <Region HBox.hgrow="ALWAYS"
                                style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-min-height: 1; -fx-max-height: 1;"/>
                        <Label text="ATAU"
                               style="-fx-text-fill: #334155;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: 700;
                                      -fx-font-family: 'Consolas', monospace;"/>
                        <Region HBox.hgrow="ALWAYS"
                                style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-min-height: 1; -fx-max-height: 1;"/>
                    </HBox>

                    <Region prefHeight="24"/>

                    <!-- Login link -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Sudah punya akun?"
                               style="-fx-text-fill: #475569;
                                      -fx-font-size: 12px;"/>
                        <Button text="Masuk sekarang"
                                onAction="#goToLogin"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #A78BFA;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: 700;
                                       -fx-cursor: hand;
                                       -fx-padding: 0;
                                       -fx-border-color: transparent;"/>
                    </HBox>
                </VBox>

                <Region prefHeight="28"/>

                <!-- Terms note -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Dengan mendaftar, Anda menyetujui"
                           style="-fx-text-fill: #334155;
                                  -fx-font-size: 11px;"/>
                    <Button text="Syarat Penggunaan"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #6366F1;
                                   -fx-font-size: 11px;
                                   -fx-cursor: hand;
                                   -fx-padding: 0;
                                   -fx-border-color: transparent;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
