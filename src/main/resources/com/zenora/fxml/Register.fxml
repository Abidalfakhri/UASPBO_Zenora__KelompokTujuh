<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.zenora.controller.RegisterController"
           prefWidth="1200"
           prefHeight="760"
           style="-fx-background-color: linear-gradient(to bottom right, #0B0F19, #111827);">

    <HBox alignment="CENTER">

        <!-- LEFT SIDE -->
        <VBox alignment="CENTER_LEFT"
              spacing="0"
              minWidth="520"
              maxWidth="520"
              style="-fx-background-color:
                     linear-gradient(to bottom right, #0F172A, #111827);
                     -fx-padding: 80 70;">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="14">

                <StackPane prefWidth="52"
                           prefHeight="52"
                           style="-fx-background-color:
                                  linear-gradient(to bottom right, #7C3AED, #4F46E5);
                                  -fx-background-radius: 16;">

                    <Label text="Z"
                           style="-fx-text-fill:white;
                                  -fx-font-size:24px;
                                  -fx-font-weight:900;"/>
                </StackPane>

                <VBox spacing="2">

                    <Label text="Zenora"
                           style="-fx-text-fill:#F8FAFC;
                                  -fx-font-size:24px;
                                  -fx-font-weight:900;"/>

                    <Label text="Personal Finance Platform"
                           style="-fx-text-fill:#A78BFA;
                                  -fx-font-size:11px;
                                  -fx-font-weight:700;
                                  -fx-font-family:'Consolas';"/>
                </VBox>
            </HBox>

            <Region minHeight="80"/>

            <!-- Hero -->
            <Label text="Mulai Bangun&#10;Masa Depan Finansial"
                   wrapText="true"
                   style="-fx-text-fill:#F8FAFC;
                          -fx-font-size:38px;
                          -fx-font-weight:900;
                          -fx-line-spacing:8;"/>

            <Region minHeight="24"/>

            <Label text="Zenora membantu kamu mengatur tabungan, dana darurat, investasi, dan target finansial dengan pengalaman yang modern dan mudah digunakan."
                   wrapText="true"
                   maxWidth="390"
                   style="-fx-text-fill:#94A3B8;
                          -fx-font-size:14px;
                          -fx-line-spacing:5;"/>

            <Region minHeight="46"/>

            <!-- Features -->
            <VBox spacing="18">

                <HBox spacing="14" alignment="CENTER_LEFT">

                    <StackPane prefWidth="28"
                               prefHeight="28"
                               style="-fx-background-color: rgba(52,211,153,0.12);
                                      -fx-background-radius: 100;">

                        <Label text="✓"
                               style="-fx-text-fill:#34D399;
                                      -fx-font-weight:900;"/>
                    </StackPane>

                    <Label text="Simulasi tabungan dan bunga otomatis"
                           style="-fx-text-fill:#CBD5E1;
                                  -fx-font-size:13px;"/>
                </HBox>

                <HBox spacing="14" alignment="CENTER_LEFT">

                    <StackPane prefWidth="28"
                               prefHeight="28"
                               style="-fx-background-color: rgba(52,211,153,0.12);
                                      -fx-background-radius: 100;">

                        <Label text="✓"
                               style="-fx-text-fill:#34D399;
                                      -fx-font-weight:900;"/>
                    </StackPane>

                    <Label text="Perencanaan dana darurat dan pensiun"
                           style="-fx-text-fill:#CBD5E1;
                                  -fx-font-size:13px;"/>
                </HBox>

                <HBox spacing="14" alignment="CENTER_LEFT">

                    <StackPane prefWidth="28"
                               prefHeight="28"
                               style="-fx-background-color: rgba(52,211,153,0.12);
                                      -fx-background-radius: 100;">

                        <Label text="✓"
                               style="-fx-text-fill:#34D399;
                                      -fx-font-weight:900;"/>
                    </StackPane>

                    <Label text="Dashboard modern dan mudah dipahami"
                           style="-fx-text-fill:#CBD5E1;
                                  -fx-font-size:13px;"/>
                </HBox>

                <HBox spacing="14" alignment="CENTER_LEFT">

                    <StackPane prefWidth="28"
                               prefHeight="28"
                               style="-fx-background-color: rgba(52,211,153,0.12);
                                      -fx-background-radius: 100;">

                        <Label text="✓"
                               style="-fx-text-fill:#34D399;
                                      -fx-font-weight:900;"/>
                    </StackPane>

                    <Label text="Data tersimpan aman dan terstruktur"
                           style="-fx-text-fill:#CBD5E1;
                                  -fx-font-size:13px;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom Cards -->
            <HBox spacing="18">

                <VBox spacing="6"
                      prefWidth="130"
                      style="-fx-background-color: rgba(255,255,255,0.04);
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-padding:18;">

                    <Label text="Smart"
                           style="-fx-text-fill:#A78BFA;
                                  -fx-font-size:22px;
                                  -fx-font-weight:900;"/>

                    <Label text="Financial Planning"
                           wrapText="true"
                           style="-fx-text-fill:#94A3B8;
                                  -fx-font-size:11px;"/>
                </VBox>

                <VBox spacing="6"
                      prefWidth="130"
                      style="-fx-background-color: rgba(255,255,255,0.04);
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-padding:18;">

                    <Label text="Secure"
                           style="-fx-text-fill:#22D3EE;
                                  -fx-font-size:22px;
                                  -fx-font-weight:900;"/>

                    <Label text="Protected Account"
                           wrapText="true"
                           style="-fx-text-fill:#94A3B8;
                                  -fx-font-size:11px;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- RIGHT SIDE -->
        <StackPane prefWidth="620"
                   style="-fx-background-color:#0B1220;">

            <VBox alignment="CENTER"
                  maxWidth="390"
                  spacing="0">

                <!-- Header -->
                <Label text="Create Account"
                       style="-fx-text-fill:#F8FAFC;
                              -fx-font-size:28px;
                              -fx-font-weight:900;"/>

                <Region minHeight="8"/>

                <Label text="Daftar untuk mulai menggunakan Zenora."
                       wrapText="true"
                       style="-fx-text-fill:#94A3B8;
                              -fx-font-size:13px;"/>

                <Region minHeight="34"/>

                <!-- Register Card -->
                <VBox spacing="0"
                      style="-fx-background-color: rgba(17,24,39,0.96);
                             -fx-background-radius: 26;
                             -fx-border-radius: 26;
                             -fx-border-color: rgba(255,255,255,0.06);
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 40, 0.2, 0, 10);">

                    <padding>
                        <Insets top="34" right="34" bottom="34" left="34"/>
                    </padding>

                    <!-- Username -->
                    <Label text="USERNAME"
                           style="-fx-text-fill:#64748B;
                                  -fx-font-size:10px;
                                  -fx-font-weight:800;
                                  -fx-letter-spacing:1.5;"/>

                    <Region minHeight="10"/>

                    <TextField fx:id="usernameField"
                               promptText="Masukkan username"
                               style="
                                   -fx-background-color:#111827;
                                   -fx-background-radius:14;
                                   -fx-border-radius:14;
                                   -fx-border-color:#1E293B;
                                   -fx-border-width:1;
                                   -fx-text-fill:white;
                                   -fx-prompt-text-fill:#64748B;
                                   -fx-font-size:13px;
                                   -fx-padding:14 16;"
                               minHeight="48"/>

                    <Region minHeight="18"/>

                    <!-- Password -->
                    <Label text="PASSWORD"
                           style="-fx-text-fill:#64748B;
                                  -fx-font-size:10px;
                                  -fx-font-weight:800;
                                  -fx-letter-spacing:1.5;"/>

                    <Region minHeight="10"/>

                    <PasswordField fx:id="passwordField"
                                   promptText="Minimal 6 karakter"
                                   style="
                                       -fx-background-color:#111827;
                                       -fx-background-radius:14;
                                       -fx-border-radius:14;
                                       -fx-border-color:#1E293B;
                                       -fx-border-width:1;
                                       -fx-text-fill:white;
                                       -fx-prompt-text-fill:#64748B;
                                       -fx-font-size:13px;
                                       -fx-padding:14 16;"
                                   minHeight="48"/>

                    <Region minHeight="18"/>

                    <!-- Confirm Password -->
                    <Label text="CONFIRM PASSWORD"
                           style="-fx-text-fill:#64748B;
                                  -fx-font-size:10px;
                                  -fx-font-weight:800;
                                  -fx-letter-spacing:1.5;"/>

                    <Region minHeight="10"/>

                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Ulangi password"
                                   style="
                                       -fx-background-color:#111827;
                                       -fx-background-radius:14;
                                       -fx-border-radius:14;
                                       -fx-border-color:#1E293B;
                                       -fx-border-width:1;
                                       -fx-text-fill:white;
                                       -fx-prompt-text-fill:#64748B;
                                       -fx-font-size:13px;
                                       -fx-padding:14 16;"
                                   minHeight="48"/>

                    <Region minHeight="12"/>

                    <!-- Labels -->
                    <Label fx:id="errorLabel"
                           text=""
                           wrapText="true"
                           style="-fx-text-fill:#F87171;
                                  -fx-font-size:11px;
                                  -fx-font-weight:700;"/>

                    <Label fx:id="successLabel"
                           text=""
                           style="-fx-text-fill:#34D399;
                                  -fx-font-size:11px;
                                  -fx-font-weight:700;"/>

                    <Label fx:id="loadingLabel"
                           text="Mendaftarkan akun..."
                           visible="false"
                           managed="false"
                           style="-fx-text-fill:#A78BFA;
                                  -fx-font-size:11px;
                                  -fx-font-weight:700;"/>

                    <Region minHeight="26"/>

                    <!-- Button -->
                    <Button fx:id="registerButton"
                            text="Create Account"
                            onAction="#handleRegister"
                            maxWidth="999"
                            minHeight="50"
                            style="
                                -fx-background-color:
                                linear-gradient(to right, #7C3AED, #4F46E5);
                                -fx-background-radius:16;
                                -fx-text-fill:white;
                                -fx-font-size:14px;
                                -fx-font-weight:800;
                                -fx-cursor:hand;"/>

                    <Region minHeight="24"/>

                    <!-- Login -->
                    <HBox alignment="CENTER" spacing="6">

                        <Label text="Sudah punya akun?"
                               style="-fx-text-fill:#64748B;
                                      -fx-font-size:12px;"/>

                        <Button text="Masuk"
                                onAction="#goToLogin"
                                style="
                                    -fx-background-color: transparent;
                                    -fx-text-fill:#A78BFA;
                                    -fx-font-size:12px;
                                    -fx-font-weight:700;
                                    -fx-cursor:hand;
                                    -fx-padding:0;
                                    -fx-border-color:transparent;"/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </HBox>
</StackPane>