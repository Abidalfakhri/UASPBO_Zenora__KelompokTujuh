<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.zenora.controller.DashboardController"
            prefWidth="1280" prefHeight="820" minWidth="980"
            styleClass="zn-root">

    <!-- ═══════════════════════════════════════════
         SIDEBAR
    ════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="zn-sidebar">

            <!-- Logo -->
            <VBox styleClass="zn-sidebar-logo-box">
                <HBox alignment="CENTER_LEFT" spacing="11">
                    <StackPane prefWidth="40" prefHeight="40"
                               style="-fx-background-color:linear-gradient(135deg,#4F46E5,#7C3AED);
                                      -fx-background-radius:11;">
                        <Label text="Z"
                               style="-fx-text-fill:white;-fx-font-size:17px;-fx-font-weight:900;"/>
                    </StackPane>
                    <VBox spacing="4">
                        <Label text="Zenora" styleClass="zn-logo-name"/>
                        <HBox alignment="CENTER_LEFT" spacing="5">
                            <Label text="●"
                                   style="-fx-text-fill:#34D399;-fx-font-size:6px;"/>
                            <Label text="LIVE" styleClass="zn-logo-version"
                                   style="-fx-text-fill:#34D399;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Nav -->
            <VBox styleClass="zn-sidebar-nav" VBox.vgrow="ALWAYS" spacing="1">

                <Label text="MENU UTAMA" styleClass="zn-nav-section-label"/>
                <Button text="  Dashboard"
                        styleClass="zn-nav-item,zn-nav-item-active"
                        maxWidth="Infinity" onAction="#stayDashboard"/>
                <Button text="  Goal Planning"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openGoal"/>
                <Button text="  Debt Payoff"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openDebtPlanner"/>
                <Button text="  Dana Darurat"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openEmergency"/>
                <Button text="  Dana Pensiun"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openRetirement"/>

                <Region prefHeight="6"/>
                <Label text="ANALYTICS" styleClass="zn-nav-section-label"/>
                <Button text="  Setoran"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openContributions"/>
                <Button text="  Reports"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openReports"/>
                <Button text="  What-If"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openWhatIf"/>

                <Region prefHeight="6"/>
                <Label text="AKUN" styleClass="zn-nav-section-label"/>
                <Button text="  Profil"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openProfile"/>
                <Button text="  Semua Modul"
                        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openMenu"/>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- Footer -->
            <VBox styleClass="zn-sidebar-footer" spacing="7">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="KAPASITAS" styleClass="zn-stat-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sidebarCapLabel" text="—"
                           styleClass="zn-sidebar-cap-value"/>
                </HBox>
                <ProgressBar fx:id="sidebarCapProgress"
                             prefWidth="99999" prefHeight="5"
                             styleClass="zn-progress-green"/>
                <Button text="Export CSV"
                        styleClass="zn-btn-secondary" maxWidth="Infinity"
                        onAction="#exportCsv"/>
                <Button text="Logout"
                        styleClass="zn-btn-danger" maxWidth="Infinity"
                        onAction="#logout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════
         CENTER
    ════════════════════════════════════════════ -->
    <center>
        <VBox styleClass="zn-root">

            <!-- ── Topbar ── -->
            <HBox styleClass="zn-topbar" alignment="CENTER_LEFT" spacing="14">
                <VBox spacing="3">
                    <Label fx:id="greetingLabel" text="Selamat datang"
                           styleClass="zn-page-title"/>
                    <Label text="DASHBOARD KEUANGAN" styleClass="zn-page-badge"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="zn-live-pill" alignment="CENTER" spacing="6">
                    <Label text="●"
                           style="-fx-text-fill:#34D399;-fx-font-size:6px;"/>
                    <Label text="LIVE" styleClass="zn-logo-version"
                           style="-fx-text-fill:#34D399;"/>
                </HBox>
                <Button text="↺  Refresh"
                        styleClass="zn-btn-secondary" onAction="#refreshClick"/>
            </HBox>

            <!-- ── Scrollable Body ── -->
            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="zn-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox styleClass="zn-body" spacing="16">

                        <!-- ════════════════════════════════
                             ROW 1 — 4 STAT CARDS
                        ════════════════════════════════ -->
                        <GridPane hgap="12" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" minWidth="185"/>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" minWidth="185"/>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" minWidth="185"/>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" minWidth="185"/>
                            </columnConstraints>

                            <!-- Card 0: Kapasitas Menabung -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="0" spacing="7">
                                <HBox alignment="CENTER_LEFT" spacing="7">
                                    <Label text="●" styleClass="zn-dot-indigo"/>
                                    <Label text="KAPASITAS MENABUNG"
                                           styleClass="zn-stat-label" wrapText="true"/>
                                </HBox>
                                <Label fx:id="capacityLabel" text="—"
                                       styleClass="zn-stat-value,zn-stat-indigo"
                                       wrapText="true"/>
                                <Label text="per bulan tersedia"
                                       styleClass="zn-panel-subtitle"/>
                            </VBox>

                            <!-- Card 1: Total Terkumpul -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="1" spacing="7">
                                <HBox alignment="CENTER_LEFT" spacing="7">
                                    <Label text="●" styleClass="zn-dot-green"/>
                                    <Label text="TOTAL TERKUMPUL"
                                           styleClass="zn-stat-label"/>
                                </HBox>
                                <Label fx:id="savedLabel" text="—"
                                       styleClass="zn-stat-value,zn-stat-green"
                                       wrapText="true"/>
                                <HBox spacing="5" alignment="CENTER_LEFT">
                                    <Label text="dari" styleClass="zn-panel-subtitle"/>
                                    <Label fx:id="targetLabel" text="—"
                                           styleClass="zn-stat-label-em" wrapText="true"/>
                                </HBox>
                            </VBox>

                            <!-- Card 2: Goals Aktif -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="2" spacing="7">
                                <HBox alignment="CENTER_LEFT" spacing="7">
                                    <Label text="●" styleClass="zn-dot-violet"/>
                                    <Label text="GOALS AKTIF"
                                           styleClass="zn-stat-label"/>
                                </HBox>
                                <Label fx:id="goalsCountLabel" text="0"
                                       styleClass="zn-stat-value,zn-stat-violet"/>
                                <HBox spacing="5" alignment="CENTER_LEFT">
                                    <Label text="Total setoran:"
                                           styleClass="zn-panel-subtitle"/>
                                    <Label fx:id="contribCountLabel" text="0"
                                           styleClass="zn-stat-label-em"/>
                                </HBox>
                            </VBox>

                            <!-- Card 3: Dana Darurat -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="3" spacing="8">
                                <HBox alignment="CENTER_LEFT" spacing="7">
                                    <Label text="●" styleClass="zn-dot-cyan"/>
                                    <Label text="DANA DARURAT"
                                           styleClass="zn-stat-label"/>
                                </HBox>
                                <Label fx:id="emergencyLabel" text="—"
                                       styleClass="zn-stat-value-sm,zn-stat-cyan"
                                       wrapText="true"/>
                                <ProgressBar fx:id="efProgress"
                                             prefWidth="99999" prefHeight="6"
                                             styleClass="zn-progress"/>
                                <Label fx:id="efStatusLabel" text="—"
                                       styleClass="zn-panel-subtitle" wrapText="true"/>
                                <Label fx:id="runwayLabel" text="—"
                                       styleClass="zn-panel-subtitle" wrapText="true"/>
                            </VBox>
                        </GridPane>

                        <!-- ════════════════════════════════
                             ROW 2 — DANA PENSIUN
                        ════════════════════════════════ -->
                        <VBox styleClass="zn-panel" spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8"
                                  styleClass="zn-panel-title-row">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="7">
                                        <Label text="●" styleClass="zn-dot-indigo"/>
                                        <Label text="Dana Pensiun"
                                               styleClass="zn-panel-title"/>
                                    </HBox>
                                    <Label text="Progres akumulasi dana hari tua Anda"
                                           styleClass="zn-panel-subtitle"/>
                                </VBox>
                                <Label fx:id="pensionPctLabel" text="—"
                                       styleClass="zn-badge,zn-badge-indigo"/>
                            </HBox>
                            <ProgressBar fx:id="pensionProgress"
                                         prefWidth="99999" prefHeight="9"
                                         styleClass="zn-progress"/>
                            <HBox alignment="CENTER_LEFT" spacing="18">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="TERKUMPUL" styleClass="zn-stat-label"/>
                                    <Label fx:id="pensionSavedLabel" text="—"
                                           styleClass="zn-stat-label-em"/>
                                </HBox>
                                <Label text="·" styleClass="zn-panel-subtitle"
                                       style="-fx-font-size:14px;"/>
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="TARGET" styleClass="zn-stat-label"/>
                                    <Label fx:id="pensionTargetLabel" text="—"
                                           styleClass="zn-stat-label-em"/>
                                </HBox>
                                <Label text="·" styleClass="zn-panel-subtitle"
                                       style="-fx-font-size:14px;"/>
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="SISA TAHUN" styleClass="zn-stat-label"/>
                                    <Label fx:id="pensionYearsLabel" text="—"
                                           styleClass="zn-stat-label-em"/>
                                </HBox>
                            </HBox>
                        </VBox>

                        <!-- ════════════════════════════════
                             ROW 3 — PROGRESS GOAL + ALERTS
                        ════════════════════════════════ -->
                        <HBox spacing="12">

                            <!-- Progress per Goal -->
                            <VBox styleClass="zn-panel" HBox.hgrow="ALWAYS"
                                  prefWidth="0" spacing="10">
                                <HBox alignment="CENTER_LEFT" spacing="8"
                                      styleClass="zn-panel-title-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="Progress per Goal"
                                               styleClass="zn-panel-title"/>
                                        <Label text="Perkembangan tiap tujuan keuangan"
                                               styleClass="zn-panel-subtitle"/>
                                    </VBox>
                                    <Button text="Pilih Goal"
                                            styleClass="zn-btn-secondary"
                                            onAction="#chooseGoalsForProgress"/>
                                </HBox>
                                <VBox fx:id="goalProgressBox" spacing="11"/>
                            </VBox>

                            <!-- Insight & Pengingat -->
                            <VBox styleClass="zn-panel" HBox.hgrow="ALWAYS"
                                  prefWidth="0" spacing="10">
                                <HBox alignment="CENTER_LEFT"
                                      styleClass="zn-panel-title-row">
                                    <VBox spacing="2">
                                        <Label text="Insight &amp; Pengingat"
                                               styleClass="zn-panel-title"/>
                                        <Label text="Notifikasi penting terkait goal Anda"
                                               styleClass="zn-panel-subtitle"/>
                                    </VBox>
                                </HBox>
                                <VBox fx:id="alertsBox" spacing="8"/>
                            </VBox>
                        </HBox>

                        <!-- ════════════════════════════════
                             ROW 4 — DISTRIBUSI PIE CHART
                        ════════════════════════════════ -->
                        <VBox styleClass="zn-panel" spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8"
                                  styleClass="zn-panel-title-row">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label text="Distribusi Target Goal"
                                           styleClass="zn-panel-title"/>
                                    <Label text="Proporsi alokasi target tiap goal"
                                           styleClass="zn-panel-subtitle"/>
                                </VBox>
                            </HBox>
                            <PieChart fx:id="allocationChart"
                                      prefHeight="260"
                                      legendVisible="true"
                                      labelsVisible="false"
                                      animated="true"/>
                        </VBox>

                        <!-- ════════════════════════════════
                             ROW 5 — GOALS TABLE
                        ════════════════════════════════ -->
                        <VBox styleClass="zn-panel" spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8"
                                  styleClass="zn-panel-title-row">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label text="Goal Anda"
                                           styleClass="zn-panel-title"/>
                                    <Label text="Daftar semua tujuan keuangan yang sedang dikelola"
                                           styleClass="zn-panel-subtitle"/>
                                </VBox>
                                <Button text="+ Goal Baru"
                                        styleClass="zn-btn-primary"
                                        onAction="#openGoal"/>
                            </HBox>

                            <TableView fx:id="recentGoalsTable"
                                       prefHeight="280"
                                       styleClass="zn-table">
                                <placeholder>
                                    <VBox styleClass="zn-empty-state"
                                          alignment="CENTER" spacing="8">
                                        <Label text="📂" styleClass="zn-empty-icon"/>
                                        <Label text="Belum ada goal"
                                               styleClass="zn-empty-title"/>
                                        <Label text="Buat goal pertama Anda untuk mulai tracking keuangan."
                                               styleClass="zn-empty-sub"
                                               wrapText="true" maxWidth="280"/>
                                    </VBox>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="colGoalName"
                                                 text="NAMA GOAL"
                                                 prefWidth="210" minWidth="150"/>
                                    <TableColumn fx:id="colGoalCat"
                                                 text="KATEGORI"
                                                 prefWidth="140" minWidth="110"/>
                                    <TableColumn fx:id="colGoalTarget"
                                                 text="TARGET"
                                                 prefWidth="165" minWidth="120"/>
                                    <TableColumn fx:id="colGoalSaved"
                                                 text="TERKUMPUL"
                                                 prefWidth="165" minWidth="120"/>
                                    <TableColumn fx:id="colGoalPct"
                                                 text="PROGRESS"
                                                 prefWidth="120" minWidth="90"/>
                                    <TableColumn fx:id="colGoalStorage"
                                                 text="DISIMPAN DI"
                                                 prefWidth="160" minWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
