<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.zenora.controller.DashboardController"
            prefWidth="1180" prefHeight="760" minWidth="900"
            styleClass="zn-root">

    <!-- ═══════ SIDEBAR ═══════ -->
    <left>
        <VBox styleClass="zn-sidebar">

            <!-- Logo -->
            <VBox styleClass="zn-sidebar-logo-box" spacing="6">
                <HBox alignment="CENTER_LEFT" spacing="11">
                    <StackPane prefWidth="38" prefHeight="38"
                               style="-fx-background-color: #4F46E5; -fx-background-radius: 11;
                                      -fx-effect: dropshadow(gaussian, rgba(79,70,229,0.55), 12, 0, 0, 3);">
                        <Label text="Z" style="-fx-text-fill:white; -fx-font-size:17px; -fx-font-weight:900;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Zenora" styleClass="zn-logo-name"/>
                        <HBox alignment="CENTER_LEFT" spacing="5">
                            <Label text="●" style="-fx-text-fill:#34D399; -fx-font-size:6px;"/>
                            <Label text="LIVE" styleClass="zn-logo-version"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Nav -->
            <VBox styleClass="zn-sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU UTAMA" styleClass="zn-nav-section-label"/>
                <Button text="⬡  Dashboard"      styleClass="zn-nav-item,zn-nav-item-active" maxWidth="Infinity" onAction="#stayDashboard"/>
                <Button text="◇  Goal Planning"  styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openGoal"/>
                <Button text="◇  Debt Payoff"    styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openDebtPlanner"/>
                <Button text="◇  Dana Darurat"   styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openEmergency"/>
                <Button text="◇  Dana Pensiun"   styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openRetirement"/>

                <Label text="ANALYTICS" styleClass="zn-nav-section-label"/>
                <Button text="◇  Setoran"        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openContributions"/>
                <Button text="◇  Reports"        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openReports"/>
                <Button text="◇  What-If"        styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openWhatIf"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Label text="AKUN" styleClass="zn-nav-section-label"/>
                <Button text="◇  Profil"         styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openProfile"/>
                <Button text="◇  Semua Modul"    styleClass="zn-nav-item" maxWidth="Infinity" onAction="#openMenu"/>
            </VBox>

            <!-- Footer -->
            <VBox styleClass="zn-sidebar-footer" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="KAPASITAS" styleClass="zn-stat-label"/>
                    <Label fx:id="sidebarCapLabel" text="—" styleClass="zn-stat-label"/>
                </HBox>
                <Button text="Export CSV" styleClass="zn-btn-secondary" maxWidth="Infinity" onAction="#exportCsv"/>
                <Button text="Logout"     styleClass="zn-btn-danger"    maxWidth="Infinity" onAction="#logout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════ CENTER ═══════ -->
    <center>
        <VBox styleClass="zn-root">

            <!-- Topbar -->
            <HBox styleClass="zn-topbar" alignment="CENTER_LEFT" spacing="14">
                <VBox spacing="2">
                    <Label fx:id="greetingLabel" text="Halo" styleClass="zn-page-title"/>
                    <Label text="DASHBOARD" styleClass="zn-page-badge"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Live badge -->
                <HBox alignment="CENTER" spacing="6"
                      style="-fx-background-color:rgba(52,211,153,0.08);
                             -fx-background-radius:20;
                             -fx-border-color:rgba(52,211,153,0.18);
                             -fx-border-radius:20; -fx-border-width:1;
                             -fx-padding:5 13;">
                    <Label text="●" style="-fx-text-fill:#34D399; -fx-font-size:6px;"/>
                    <Label text="LIVE" styleClass="zn-logo-version" style="-fx-text-fill:#34D399;"/>
                </HBox>
                <Button text="↺  Refresh" styleClass="zn-btn-secondary" onAction="#refreshClick"/>
            </HBox>

            <!-- Scrollable body -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="zn-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox styleClass="zn-body" spacing="16">

                        <!-- ── STAT CARDS ── -->
                        <GridPane hgap="14" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <!-- Kapasitas -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="0" spacing="8">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="●" styleClass="zn-dot-indigo"/>
                                    <Label text="KAPASITAS MENABUNG" styleClass="zn-stat-label"/>
                                </HBox>
                                <Label fx:id="capacityLabel" text="—" styleClass="zn-stat-value,zn-stat-indigo"/>
                                <Label text="per bulan tersedia" styleClass="zn-stat-label"/>
                            </VBox>

                            <!-- Total Terkumpul -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="1" spacing="8">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="●" styleClass="zn-dot-green"/>
                                    <Label text="TOTAL TERKUMPUL" styleClass="zn-stat-label"/>
                                </HBox>
                                <Label fx:id="savedLabel" text="—" styleClass="zn-stat-value,zn-stat-green"/>
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label text="dari" styleClass="zn-stat-label"/>
                                    <Label fx:id="targetLabel" text="—" styleClass="zn-stat-label"/>
                                </HBox>
                            </VBox>

                            <!-- Goals Aktif -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="2" spacing="8">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="●" styleClass="zn-dot-violet"/>
                                    <Label text="GOALS AKTIF" styleClass="zn-stat-label"/>
                                </HBox>
                                <Label fx:id="goalsCountLabel" text="0" styleClass="zn-stat-value,zn-stat-violet"/>
                                <HBox spacing="5" alignment="CENTER_LEFT">
                                    <Label text="setoran:" styleClass="zn-stat-label"/>
                                    <Label fx:id="contribCountLabel" text="0" styleClass="zn-stat-label"/>
                                </HBox>
                            </VBox>

                            <!-- Dana Darurat -->
                            <VBox styleClass="zn-panel" GridPane.columnIndex="3" spacing="8">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="●" styleClass="zn-dot-cyan"/>
                                    <Label text="DANA DARURAT" styleClass="zn-stat-label"/>
                                </HBox>
                                <Label fx:id="emergencyLabel" text="—" styleClass="zn-stat-value-sm"/>
                                <ProgressBar fx:id="efProgress" prefWidth="99999" prefHeight="7" styleClass="zn-progress"/>
                                <Label fx:id="efStatusLabel" text="—" styleClass="zn-stat-label" wrapText="true"/>
                                <Label fx:id="runwayLabel"   text="—" styleClass="zn-stat-label" wrapText="true"/>
                            </VBox>
                        </GridPane>

                        <!-- ── DANA PENSIUN ── -->
                        <VBox styleClass="zn-panel" spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="zn-panel-title-row">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="●" styleClass="zn-dot-indigo"/>
                                    <Label text="Dana Pensiun" styleClass="zn-panel-title"/>
                                </HBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="pensionPctLabel" text="—" styleClass="zn-badge"/>
                            </HBox>
                            <ProgressBar fx:id="pensionProgress" prefWidth="99999" prefHeight="10" styleClass="zn-progress"/>
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label fx:id="pensionSavedLabel" text="Terkumpul: —" styleClass="zn-stat-label"/>
                                <Label text="/" styleClass="zn-stat-label"/>
                                <Label fx:id="pensionTargetLabel" text="Target: —"   styleClass="zn-stat-label"/>
                            </HBox>
                        </VBox>

                        <!-- ── PROGRESS PER GOAL ── -->
                        <VBox styleClass="zn-panel" spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="zn-panel-title-row">
                                <Label text="Progress per Goal" styleClass="zn-panel-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Atur Goal" styleClass="zn-btn-secondary" onAction="#chooseGoalsForProgress"/>
                            </HBox>
                            <VBox fx:id="goalProgressBox" spacing="10"/>
                        </VBox>

                        <!-- ── ALERTS + PIE ── -->
                        <HBox spacing="16">
                            <VBox styleClass="zn-panel" HBox.hgrow="ALWAYS" spacing="10">
                                <HBox alignment="CENTER_LEFT" styleClass="zn-panel-title-row">
                                    <Label text="Insight &amp; Pengingat" styleClass="zn-panel-title"/>
                                </HBox>
                                <VBox fx:id="alertsBox" spacing="6"/>
                            </VBox>

                            <VBox styleClass="zn-panel" HBox.hgrow="ALWAYS" spacing="10">
                                <HBox alignment="CENTER_LEFT" styleClass="zn-panel-title-row">
                                    <Label text="Distribusi Target Goal" styleClass="zn-panel-title"/>
                                </HBox>
                                <PieChart fx:id="allocationChart" prefHeight="260"/>
                            </VBox>
                        </HBox>

                        <!-- ── GOALS TABLE ── -->
                        <VBox styleClass="zn-panel" spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="zn-panel-title-row">
                                <Label text="Goal Anda" styleClass="zn-panel-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="+ Goal Baru" styleClass="zn-btn-primary" onAction="#openGoal"/>
                            </HBox>
                            <TableView fx:id="recentGoalsTable" prefHeight="260" styleClass="zn-table">
                                <placeholder>
                                    <VBox styleClass="zn-empty-state" alignment="CENTER" spacing="8">
                                        <Label text="📂" styleClass="zn-empty-icon"/>
                                        <Label text="Belum ada goal" styleClass="zn-empty-title"/>
                                        <Label text="Buat goal pertama Anda untuk mulai tracking." styleClass="zn-empty-sub"/>
                                    </VBox>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="colGoalName"    text="NAMA"        prefWidth="220"/>
                                    <TableColumn fx:id="colGoalCat"     text="KATEGORI"    prefWidth="160"/>
                                    <TableColumn fx:id="colGoalTarget"  text="TARGET"      prefWidth="180"/>
                                    <TableColumn fx:id="colGoalSaved"   text="TERKUMPUL"   prefWidth="180"/>
                                    <TableColumn fx:id="colGoalPct"     text="PROGRESS"    prefWidth="120"/>
                                    <TableColumn fx:id="colGoalStorage" text="DISIMPAN DI" prefWidth="180"/>
                                </columns>
                            </TableView>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
